# Copy to /etc/multi-detect/runtime.env, chmod 0600, and replace every value.
# Never commit the real file because CAMERA_SOURCE and ALERT_HMAC_KEY contain credentials.
CAMERA_SOURCE=rtsp://USER:PASSWORD@CAMERA_HOST:554/STREAM
ALERT_RECEIVER_HOST=192.0.2.1
ALERT_RECEIVER_PORT=14600
ALERT_HMAC_KEY=REPLACE_WITH_RANDOM_SECRET_OF_AT_LEAST_32_BYTES
ALERT_SENDER_ID=aircraft-1
ALERT_RECEIVER_ID=ground-station-1
# The production service uses a TensorRT 8.6 engine built and validated on the
# target Jetson/JetPack combination. CPU-only ONNX Runtime is a validation
# fallback, not an accepted aircraft service backend.
FIRE_MODEL_PATH=/opt/multi-detect/models/fire-smoke-nms.engine
FIRE_MODEL_MANIFEST=/opt/multi-detect/models/fire-smoke-nms.engine.manifest.json
FIRE_MODEL_CLASS_NAMES=flame,smoke
FIRE_MODEL_OUTPUT_COORDINATES=letterbox_xyxy_px
FIRE_CONFIDENCE_THRESHOLD=0.10
FIRE_FLAME_CONFIDENCE_THRESHOLD=0.25
# FIRESENSE smoke regression default; keep the three-frame temporal gate below.
FIRE_SMOKE_CONFIDENCE_THRESHOLD=0.30
FIRE_CANDIDATE_STABILITY_FRAMES=3
# Live ground-overlay cadence profile: detector observations are staggered while
# selected TRK/LCK boxes continue through the metadata-only short-term tracker.
PRIMARY_FIRE_MODEL_FRAME_STRIDE=2
PRIMARY_FIRE_MODEL_FRAME_PHASE=0
LOCK_MODEL_FORCE_EVERY_FRAME=0
# Optional person/firefighter-only appearance gates for the unified target pool.
# These values do not enable PERSON_REID_ENABLED by themselves and do not change
# vehicle or aircraft association thresholds.
UNIFIED_TARGET_POOL_PERSON_MAXIMUM_APPEARANCE_DISTANCE=0.70
UNIFIED_TARGET_POOL_PERSON_STRICT_REID_DISTANCE=0.22
PIXHAWK_HARDWARE_PROFILE=holybro_pixhawk_jetson_baseboard
# V6X 192.168.0.3 broadcasts MAVLink 2 to 192.168.0.255:14550 over the
# carrier's internal Ethernet switch. The Jetson must also own 192.168.0.1/24.
PIXHAWK_ENDPOINT=udp:0.0.0.0:14550
# Ignored by the UDP transport; retained for the shared CLI and THS1 fallback.
PIXHAWK_BAUD=921600
PIXHAWK_SYSTEM_ID=1
PIXHAWK_EXPECTED_AUTOPILOT=px4
PIXHAWK_EXPECTED_VEHICLE_TYPE=fixed_wing
TASK_AREA_MISSION_SEQUENCE=3

# The production patrol service does not consume payload HIL variables. For a separate,
# propeller-off localhost HIL session, inject three different 32+ byte secrets at runtime:
# HIL_REQUEST_KEY=DO_NOT_STORE_REAL_KEYS_IN_THIS_TEMPLATE
# HIL_RESULT_KEY=DO_NOT_STORE_REAL_KEYS_IN_THIS_TEMPLATE
# HIL_CONFIRM_KEY=DO_NOT_STORE_REAL_KEYS_IN_THIS_TEMPLATE
