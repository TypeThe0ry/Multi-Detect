{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.invalid/multi-detect/mission.schema.json",
  "title": "Multi-Detect mission configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "mission_id",
    "mission_type",
    "platform_mode",
    "payloads",
    "target_classes",
    "human_authorization_required"
  ],
  "properties": {
    "mission_id": {"type": "string", "minLength": 1},
    "mission_type": {
      "enum": [
        "fire_suppression",
        "rescue_supply",
        "communication_relay",
        "environmental_sensor",
        "agriculture",
        "industrial_sensor",
        "multipoint_logistics",
        "search_and_rescue"
      ]
    },
    "platform_mode": {"enum": ["disposable", "multi_deployment"]},
    "payload_count": {"type": "integer", "minimum": 0},
    "payloads": {
      "type": "array",
      "minItems": 0,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["slot_id", "payload_type"],
        "properties": {
          "slot_id": {"type": "string", "minLength": 1},
          "payload_type": {"type": "string", "minLength": 1}
        }
      }
    },
    "target_classes": {
      "type": "array",
      "minItems": 1,
      "items": {"type": "string", "minLength": 1}
    },
    "human_authorization_required": {"const": true},
    "minimum_confidence": {"type": "number", "minimum": 0, "maximum": 1},
    "minimum_track_time_seconds": {"type": "number", "minimum": 0},
    "minimum_track_observations": {"type": "integer", "minimum": 2},
    "maximum_track_gap_seconds": {"type": "number", "exclusiveMinimum": 0},
    "target_reengagement_cooldown_seconds": {
      "type": "number",
      "exclusiveMinimum": 0
    },
    "person_exclusion_enabled": {"type": "boolean"},
    "person_labels": {
      "type": "array",
      "items": {"type": "string", "minLength": 1}
    },
    "require_independent_rgb_corroboration": {"type": "boolean"},
    "require_thermal_corroboration": {"type": "boolean"},
    "completion_policy": {
      "enum": ["terminate_after_first", "continue_while_payload_available"]
    },
    "ruleset_version": {"type": "string", "minLength": 1},
    "safety": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "minimum_altitude_agl_m": {"type": "number", "minimum": 0},
        "maximum_altitude_agl_m": {"type": "number", "exclusiveMinimum": 0},
        "maximum_abs_roll_deg": {"type": "number", "exclusiveMinimum": 0},
        "maximum_abs_pitch_deg": {"type": "number", "exclusiveMinimum": 0},
        "minimum_ground_speed_mps": {"type": "number", "minimum": 0},
        "maximum_ground_speed_mps": {"type": "number", "minimum": 0},
        "person_exclusion_margin_normalized": {
          "type": "number",
          "minimum": 0,
          "maximum": 0.5
        },
        "sensor_data_max_age_seconds": {"type": "number", "exclusiveMinimum": 0},
        "authorization_ttl_seconds": {"type": "number", "exclusiveMinimum": 0},
        "release_confirmation_timeout_seconds": {
          "type": "number",
          "exclusiveMinimum": 0
        }
      }
    },
    "fixed_wing_release_window": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "calibration_id",
        "camera_horizontal_fov_deg",
        "camera_vertical_fov_deg",
        "camera_mount_down_angle_deg",
        "payload_descent_time_factor",
        "command_to_release_latency_seconds",
        "maximum_cross_track_error_m",
        "release_window_half_length_m",
        "hil_only"
      ],
      "properties": {
        "calibration_id": {"type": "string", "minLength": 1},
        "camera_horizontal_fov_deg": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 180
        },
        "camera_vertical_fov_deg": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 180
        },
        "camera_mount_down_angle_deg": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 90
        },
        "payload_descent_time_factor": {"type": "number", "exclusiveMinimum": 0},
        "command_to_release_latency_seconds": {"type": "number", "minimum": 0},
        "maximum_cross_track_error_m": {"type": "number", "exclusiveMinimum": 0},
        "release_window_half_length_m": {"type": "number", "exclusiveMinimum": 0},
        "minimum_depression_angle_deg": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 90
        },
        "maximum_depression_angle_deg": {
          "type": "number",
          "exclusiveMinimum": 0,
          "exclusiveMaximum": 90
        },
        "gravity_mps2": {"type": "number", "exclusiveMinimum": 0},
        "require_multimodal_range": {"type": "boolean"},
        "maximum_range_age_s": {"type": "number", "exclusiveMinimum": 0},
        "minimum_range_target_iou": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 1
        },
        "minimum_range_sensor_consistency": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "payload_mass_kg": {"type": "number", "exclusiveMinimum": 0},
        "payload_mass_sigma_kg": {"type": "number", "minimum": 0},
        "drag_coefficient": {"type": "number", "exclusiveMinimum": 0},
        "drag_coefficient_sigma": {"type": "number", "minimum": 0},
        "reference_area_m2": {"type": "number", "exclusiveMinimum": 0},
        "air_density_kg_m3": {"type": "number", "exclusiveMinimum": 0},
        "wind_sigma_mps": {"type": "number", "minimum": 0},
        "ground_velocity_sigma_mps": {"type": "number", "minimum": 0},
        "altitude_sigma_m": {"type": "number", "minimum": 0},
        "release_latency_sigma_s": {"type": "number", "minimum": 0},
        "maximum_air_data_disagreement_mps": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "maximum_error_ellipse_major_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "maximum_error_ellipse_minor_m": {
          "type": "number",
          "exclusiveMinimum": 0
        },
        "integration_step_seconds": {
          "type": "number",
          "exclusiveMinimum": 0,
          "maximum": 0.05
        },
        "maximum_flight_time_seconds": {"type": "number", "exclusiveMinimum": 0},
        "hil_only": {"const": true}
      }
    }
  }
}
